#
# Public web-root rules.
#
# index.php is the front controller, and UTF-8 is the expected encoding for the
# multilingual site. Markdown and log files are blocked from direct download so
# operational notes or runtime logs are not exposed if they exist in production.
#
DirectoryIndex index.php
AddDefaultCharset UTF-8

<FilesMatch "\.(log|md)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
