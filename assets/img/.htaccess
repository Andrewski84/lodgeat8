#
# Upload hardening for public images.
#
# The admin area stores uploaded images under assets/img/. Images must remain
# directly readable by browsers, but executable file types should never run from
# this directory. This protects the site even if a hostile file bypasses upload
# validation on a misconfigured host.
#
<FilesMatch "\.(php|phtml|phar|php[0-9]?|cgi|pl|asp|aspx|jsp)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

<IfModule mod_php.c>
    php_flag engine off
</IfModule>
